<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="App01NumeroDaSolrte.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <VerticalStackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
        <Image
            HeightRequest="115"
            Source="logo_green.png"
            WidthRequest="74" />

        <!--  margin é margem no topo  -->
        <Label
            Margin="0,20,0,120"
            HorizontalOptions="Center"
            Text="Número da sorte"
            TextColor="#00AB37"
            VerticalOptions="Center" />

        <Button HorizontalOptions="Center" Text="Gerar números da sorte" />
    </VerticalStackLayout>
</ContentPage>